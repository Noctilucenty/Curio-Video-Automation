# --- AI (the brain) ---
# Missing key => deterministic mock mode (full pipeline works offline).
# Hard rule: Curio content uses gpt-5-mini (or newer approved) — never 4o-mini.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini

# --- Narration voice (ElevenLabs; HeyGen only lip-syncs to this audio) ---
# ELEVENLABS_VOICE_ID = the Zack D Films-style narration voice in your account.
# Missing key => mock voice.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL=eleven_multilingual_v2

# --- Video rendering (HeyGen only renders; it never decides content) ---
# HEYGEN_VOICE_ID is only the fallback TTS if ElevenLabs synthesis fails.
# Missing key => mock renderer (instant fake MP4 URL).
HEYGEN_API_KEY=
HEYGEN_AVATAR_ID=
HEYGEN_VOICE_ID=

# --- Post-processing (captions only; timeline never trimmed for a locked master) ---
# Missing key => mock (raw render passes through, flagged as uncaptioned).
# Current live contract is Mirage (api.mirage.app). Legacy api.captions.ai is 502.
# CAPTIONS_API_BASE only if your account's docs show a different base host.
CAPTIONS_API_KEY=
CAPTIONS_API_BASE=
# Mirage caption style template id (required for the Mirage upload contract).
MIRAGE_CAPTION_TEMPLATE_ID=
# Set to 1 ONLY if the account honors a custom caption track with exact timing.
# Default (0/unset) = auto-transcription only => a curated locked master is
# REFUSED rather than auto-captioned (reveal protection).
MIRAGE_CUSTOM_CAPTION_TIMING=

# --- Server ---
PORT=8790
# When set, every mutating endpoint requires "Authorization: Bearer <token>".
# Leave empty for open local dev.
ADMIN_TOKEN=

# Where the JSON snapshot DB lives (dev persistence; Postgres schema in db/schema.sql).
DATA_DIR=./data

# --- Renderer: local (no-avatar dark editorial, default) | heygen | mock ---
RENDERER=local
