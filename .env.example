# --- AI (the brain) ---
# Missing key => deterministic mock mode (full pipeline works offline).
# Hard rule: Curio content uses gpt-5-mini (or newer approved) — never 4o-mini.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini

# --- Video rendering (HeyGen only renders; it never decides content) ---
# Missing key => mock renderer (instant fake MP4 URL).
HEYGEN_API_KEY=
HEYGEN_AVATAR_ID=
HEYGEN_VOICE_ID=

# --- Server ---
PORT=8790
# When set, every mutating endpoint requires "Authorization: Bearer <token>".
# Leave empty for open local dev.
ADMIN_TOKEN=

# Where the JSON snapshot DB lives (dev persistence; Postgres schema in db/schema.sql).
DATA_DIR=./data
