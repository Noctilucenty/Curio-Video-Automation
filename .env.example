# Curio Automation — environment. Copy to .env for local dev.
# RULE: a missing key degrades to a mock provider. It never crashes at boot.

# --- web / auth -------------------------------------------------------------
PORT=8790

# PRIVATE BY DEFAULT. Every /api route (GET included), /videos/* and all artifacts
# require a credential. The server REFUSES TO BOOT with NODE_ENV=production and no
# credential configured, so a misconfigured deploy fails loudly instead of silently
# publishing the dashboard.

# Browser login. REQUIRED in production — startup ABORTS without it, because a bearer
# token alone cannot sign a human into the dashboard.
# Issues an HttpOnly+Secure+SameSite=Strict cookie; never stored in the browser.
ADMIN_PASSWORD=

# Signs the session cookie and short-lived artifact URLs.
# REQUIRED in production (startup ABORTS without it) and must be >= 32 chars.
# Dev uses a random per-boot value — which is exactly why production must set it:
# otherwise every restart would silently invalidate all sessions.
#   openssl rand -hex 32
SESSION_SECRET=

# Optional bearer token for API clients / CI. Not used by the dashboard.
# Compared in constant time.
ADMIN_TOKEN=

# Comma-separated origins allowed to make state-changing requests.
# Empty = same-origin only (correct for a single Render service).
ALLOWED_ORIGINS=

# Escape hatch for local dev ONLY: run with no credentials at all.
# Ignored in production — assertBootSecurity still refuses to start.
ALLOW_INSECURE_NO_AUTH=

# --- durable control plane (Render provisions both) -------------------------
# Unset => in-memory store + in-process queue. Fine for tests, NOT for production:
# runs would be lost on every deploy.
DATABASE_URL=
REDIS_URL=

# --- object storage (S3-compatible: Cloudflare R2 or AWS S3) ----------------
# Render's filesystem is ephemeral; masters written to disk vanish on deploy.
STORAGE_DRIVER=local        # local | s3
S3_ENDPOINT=
S3_BUCKET=
S3_REGION=auto
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# --- providers --------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL=eleven_v3
GEMINI_API_KEY=
YOUTUBE_API_KEY=

# Captions.ai. NOTE: api.captions.ai/api/edit/submit was returning 502 even for an
# invalid key as of 2026-07-20 — it fails before auth, so the service is degraded.
# When unusable the run parks in BLOCKED_CAPTIONS_AUTH rather than silently
# substituting the local caption engine.
CAPTIONS_API_KEY=
CAPTIONS_API_BASE=

# --- worker -----------------------------------------------------------------
CURIO_ROLE=web              # web | worker
WORKER_CONCURRENCY=1        # >1 risks two paid calls for one stage if a lease mistimes
DATA_DIR=./data
RENDERER=local
CARDS_FROZEN=1

# --- rendering ---------------------------------------------------------------
# Caption rasterizer. Default is the portable Pillow tool (tools/caption_render.py),
# which is the only one that works on Linux/Render. "swift" is an optional
# macOS-local adapter (tools/caption_render.swift, needs Xcode).
CAPTION_RASTERIZER=          # python (default) | swift
PYTHON_BIN=python3
