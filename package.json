{
  "name": "curio-automation",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Curio short-form video automation: OpenAI = brain, HeyGen = renderer, DB = memory + learning loop",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "NODE_OPTIONS='--max-old-space-size=1408' tsc -p tsconfig.json",
    "start": "node dist/src/server.js",
    "test": "NODE_OPTIONS='--max-old-space-size=1408' vitest run",
    "typecheck": "NODE_OPTIONS='--max-old-space-size=1408' tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "express": "^5.2.1",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.3",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.0",
    "tsx": "^4.20.0",
    "typescript": "^5.9.0",
    "vitest": "^3.2.0"
  }
}
