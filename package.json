{
  "name": "curio-automation",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Curio short-form video automation: OpenAI = brain, HeyGen = renderer, DB = memory + learning loop",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/server.js",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "worker": "tsx watch src/worker.ts",
    "worker:prod": "node dist/src/worker.js",
    "migrate": "psql \"$DATABASE_URL\" -f db/migrations/001_autopilot.sql"
  },
  "dependencies": {
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.5.4",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.3",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.0",
    "tsx": "^4.20.0",
    "typescript": "^5.9.0",
    "vitest": "^3.2.0"
  },
  "optionalDependencies": {
    "bullmq": "^5.34.0",
    "pg": "^8.13.1"
  }
}
